# Copy this file to .env (root) or set these in Vercel's Environment Variables dashboard.
# DO NOT commit .env to git.

# ── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Get this from your Neon project dashboard → Connection string (pooled)
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# ── Auth ────────────────────────────────────────────────────────────────────
# Any long random string, e.g.:  openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret

# ── AI ──────────────────────────────────────────────────────────────────────
# Google AI Studio → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── Email (Resend) ──────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_key

# ── App URLs ────────────────────────────────────────────────────────────────
# After deploying, set this to your Vercel frontend URL (no trailing slash)
# Used in password-reset emails.
CLIENT_URL=https://your-app.vercel.app

# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
